{
  "mcpServers": {
    "langfuse-pe-agent": {
      "command": "npx",
      "args": ["-y", "langfuse-observability-mcp-server"],
      "env": {
        "LANGFUSE_PUBLIC_KEY": "<your-public-key>",
        "LANGFUSE_SECRET_KEY": "<your-secret-key>",
        "LANGFUSE_BASE_URL": "<your-langfuse-url>"
      },
      "disabled": false,
      "autoApprove": ["get_traces", "get_trace_detail", "get_observations", "get_observation"]
    },
    "bedrock-agentcore-mcp-server": {
      "command": "uvx",
      "args": ["awslabs.amazon-bedrock-agentcore-mcp-server@latest"],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR"
      },
      "disabled": false,
      "autoApprove": ["search_agentcore_docs", "fetch_agentcore_doc"]
    }
  }
}
