term = xterm-256color

# --- Window ---
macos-non-native-fullscreen = true
macos-option-as-alt = left
window-save-state = always
window-colorspace = display-p3
window-padding-x = 14
window-padding-y = 10
confirm-close-surface = false

# --- Behavior ---
mouse-hide-while-typing = true
copy-on-select = clipboard
link-url = true
shell-integration = fish
shell-integration-features = cursor,sudo,title

# --- Cursor ---
cursor-style = bar
cursor-style-blink = true

# --- Font ---
font-family = JetBrains Mono
font-family-bold = JetBrains Mono Bold
font-family-italic = JetBrains Mono Italic
font-family-bold-italic = JetBrains Mono Bold Italic
font-size = 16
font-thicken = true
adjust-cursor-thickness = 175%
adjust-cell-width = -4%
adjust-cell-height = 30%

# --- Tokyo Night palette ---
background = #1a1b26
foreground = #c0caf5
cursor-color = #c0caf5
selection-background = #283457
selection-foreground = #c0caf5
background-opacity = 0.9
background-blur = 15
unfocused-split-opacity = 0.80
focus-follows-mouse = true

palette = 0=#15161e
palette = 1=#f7768e
palette = 2=#9ece6a
palette = 3=#e0af68
palette = 4=#7aa2f7
palette = 5=#bb9af7
palette = 6=#7dcfff
palette = 7=#a9b1d6
palette = 8=#414868
palette = 9=#f7768e
palette = 10=#9ece6a
palette = 11=#e0af68
palette = 12=#7aa2f7
palette = 13=#bb9af7
palette = 14=#7dcfff
palette = 15=#c0caf5

# --- Scrollback (25MB — essential for long Claude Code sessions) ---
scrollback-limit = 25000000

# ============================================
# SAND Keybindings
# ============================================
# S = Split    | A = Across    | N = Navigate    | D = Destroy

keybind = super+f=toggle_fullscreen
keybind = super+v=performable:paste_from_clipboard

# --- S: Split (create panels) ---
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down

# --- A: Across (tabs) ---
keybind = super+t=new_tab
keybind = super+shift+left=previous_tab
keybind = super+shift+right=next_tab

# --- N: Navigate (move between splits) ---
keybind = super+alt+left=goto_split:left
keybind = super+alt+right=goto_split:right
keybind = super+alt+up=goto_split:top
keybind = super+alt+down=goto_split:bottom
keybind = super+shift+e=equalize_splits
keybind = super+shift+f=toggle_split_zoom

# --- N: Navigate (resize splits) ---
keybind = super+ctrl+left=resize_split:left,40
keybind = super+ctrl+right=resize_split:right,40
keybind = super+ctrl+up=resize_split:up,40
keybind = super+ctrl+down=resize_split:down,40

# --- D: Destroy (close) ---
keybind = super+w=close_surface

# --- Utilities ---
keybind = super+shift+comma=reload_config
