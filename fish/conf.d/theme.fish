# Tokyo Night — Fish Colors
# https://github.com/enkia/tokyo-night-vscode-theme

# Syntax
set -g fish_color_normal c0caf5
set -g fish_color_command 7aa2f7 --bold
set -g fish_color_keyword bb9af7
set -g fish_color_quote 9ece6a
set -g fish_color_redirection e0af68
set -g fish_color_end bb9af7
set -g fish_color_error f7768e --bold
set -g fish_color_param c0caf5
set -g fish_color_option 7dcfff
set -g fish_color_comment 565f89 --italics
set -g fish_color_operator e0af68
set -g fish_color_escape 7dcfff
set -g fish_color_autosuggestion 565f89
set -g fish_color_valid_path --underline
set -g fish_color_cancel f7768e

# Selection & search
set -g fish_color_selection --background=283457
set -g fish_color_search_match --background=283457
set -g fish_color_history_current --bold

# Prompt
set -g fish_color_cwd 7aa2f7
set -g fish_color_cwd_root f7768e
set -g fish_color_user 9ece6a
set -g fish_color_host 9ece6a
set -g fish_color_host_remote e0af68
set -g fish_color_status f7768e

# Pager (tab completions)
set -g fish_pager_color_completion c0caf5
set -g fish_pager_color_description 565f89
set -g fish_pager_color_prefix 7aa2f7 --bold
set -g fish_pager_color_progress 565f89
set -g fish_pager_color_selected_background --background=283457
set -g fish_pager_color_selected_prefix 7aa2f7 --bold
set -g fish_pager_color_selected_completion c0caf5
set -g fish_pager_color_selected_description a9b1d6
