model = "gpt-5.3-codex"
model_reasoning_effort = "xhigh"
personality = "friendly"

# Add your project trust levels:
# [projects."/path/to/project"]
# trust_level = "trusted"

[features]
unified_exec = true
shell_snapshot = true
undo = true
memories = true
sqlite = true
steer = true
multi_agent = true
voice_transcription = true
realtime_conversation = true
prevent_idle_sleep = true
default_mode_request_user_input = true
responses_websockets_v2 = true
apps = true
js_repl = true

[tui]
status_line = ["model-with-reasoning", "git-branch", "context-used", "five-hour-limit", "used-tokens"]

[mcp_servers.deepwiki]
url = "https://mcp.deepwiki.com/mcp"

[mcp_servers.strands-agents]
command = "$HOME/.local/bin/strands-agents-mcp-server"

[mcp_servers.strands-agents.env]
FASTMCP_LOG_LEVEL = "INFO"
PYTHONUNBUFFERED = "1"

[mcp_servers.bedrock-agentcore-mcp-server]
command = "uvx"
args = ["awslabs.amazon-bedrock-agentcore-mcp-server@latest"]

[mcp_servers.bedrock-agentcore-mcp-server.env]
FASTMCP_LOG_LEVEL = "ERROR"

model_reasoning_summary = "detailed"
hide_agent_reasoning = "false"
show_raw_agent_reasoning = "true"
